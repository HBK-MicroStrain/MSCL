{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "../linux-package.json",
    "../../release-package.json"
  ],
  "packagePresets": [
    {
      "name": "unix-release",
      "displayName": "Creates a Unix release package",
      "description": "This creates a Unix release package",
      "inherits": [
        "linux",
        "release"
      ],
      "environment": {
        "MICROSTRAIN_BUILD_DIR_RELEASE": "$env{MICROSTRAIN_BINARY_DIR}"
      },
      "hidden": true
    }
  ]
}
