{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "packagePresets": [
    {
      "name": "windows",
      "displayName": "Creates a Windows package",
      "description": "This creates a Windows package",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "hidden": true
    }
  ]
}
