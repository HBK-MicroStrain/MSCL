{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "msvc-configure.json",
    "../windows-build.json"
  ],
  "buildPresets": [
    {
      "name": "msvc-release",
      "configuration": "Release",
      "configurePreset": "msvc",
      "hidden": true
    },
    {
      "name": "msvc-debug",
      "configuration": "Debug",
      "configurePreset": "msvc",
      "hidden": true
    },
    {
      "name": "msvc-x64-release",
      "inherits": "msvc-release",
      "configurePreset": "msvc-x64",
      "hidden": true
    },
    {
      "name": "msvc-x64-debug",
      "inherits": "msvc-debug",
      "configurePreset": "msvc-x64",
      "hidden": true
    },
    {
      "name": "msvc-x86-release",
      "inherits": "msvc-release",
      "configurePreset": "msvc-x86",
      "hidden": true
    },
    {
      "name": "msvc-x86-debug",
      "inherits": "msvc-debug",
      "configurePreset": "msvc-x86",
      "hidden": true
    }
  ]
}
