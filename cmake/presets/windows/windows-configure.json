{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "../configure.json"
  ],
  "configurePresets": [
    {
      "name": "windows",
      "displayName": "Windows only configuration",
      "description": "This configuration is only available on Windows",
      "inherits": "default",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "hidden": true
    },
    {
      "name": "csharp",
      "displayName": "Enables C# bindings",
      "description": "This configuration enables C# bindings",
      "inherits": "windows",
      "cacheVariables": {
        "MSCL_BUILD_CSHARP": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "csharp-examples",
      "displayName": "Enable C# examples",
      "description": "This configuration enables C# examples",
      "inherits": "csharp",
      "cacheVariables": {
        "MSCL_BUILD_CSHARP_EXAMPLES": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "docs",
      "displayName": "Enables documentation",
      "description": "This configuration enables documentation",
      "inherits": "windows",
      "cacheVariables": {
        "MSCL_BUILD_DOCUMENTATION": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "windows-static-all",
      "displayName": "Enables all project options with static C++ library configurations for Windows",
      "description": "This configuration enables all project options with static C++ library configurations for Windows",
      "inherits": [
        "static-all",
        "csharp",
        "csharp-examples",
        "docs"
      ],
      "hidden": true
    }
  ]
}
