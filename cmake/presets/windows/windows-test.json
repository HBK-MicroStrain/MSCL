{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "../test.json"
  ],
  "testPresets": [
    {
      "name": "windows",
      "displayName": "Windows only test",
      "description": "This test is only available on Windows",
      "inherits": [
        "default"
      ],
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "hidden": true
    }
  ]
}
