{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "windows-configure.json",
    "../build.json"
  ],
  "buildPresets": [
    {
      "name": "docs",
      "configurePreset": "docs",
      "targets": [
        "MSCL-Docs"
      ],
      "hidden": true
    },
    {
      "name": "docs-package",
      "inherits": "docs",
      "configurePreset": "docs-package",
      "hidden": true
    },
    {
      "name": "csharp",
      "configurePreset": "csharp",
      "targets": [
        "MSCL-CSharp"
      ],
      "hidden": true
    },
    {
      "name": "csharp-package",
      "inherits": "csharp",
      "configurePreset": "csharp-package",
      "hidden": true
    },
    {
      "name": "csharp-examples",
      "configurePreset": "csharp-examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    }
  ]
}
