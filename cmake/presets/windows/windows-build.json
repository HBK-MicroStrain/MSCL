{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "windows-configure.json",
    "../build.json"
  ],
  "buildPresets": [
    {
      "name": "windows",
      "displayName": "Windows only build",
      "description": "This build is only available on Windows",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      },
      "hidden": true
    },
    {
      "name": "csharp",
      "displayName": "Builds C# bindings",
      "description": "This builds C# bindings",
      "inherits": [
        "windows"
      ],
      "targets": [
        "MSCL-CSharp"
      ],
      "hidden": true
    },
    {
      "name": "csharp-examples",
      "displayName": "Builds C# examples",
      "description": "This builds C# examples",
      "inherits": [
        "windows"
      ],
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    },
    {
      "name": "docs",
      "displayName": "Builds documentation",
      "description": "This builds documentation",
      "inherits": [
        "windows"
      ],
      "targets": [
        "MSCL-Docs"
      ],
      "hidden": true
    },
    {
      "name": "windows-static-all",
      "displayName": "Builds all configurations, including Windows-specific, with static C++ libraries",
      "description": "This builds all configurations, including Windows-specific, with static C++ libraries",
      "inherits": [
        "static-all",
        "csharp",
        "csharp-examples",
        "docs"
      ],
      "hidden": true
    }
  ]
}
