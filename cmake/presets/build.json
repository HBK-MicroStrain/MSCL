{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "configure.json"
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configuration": "Debug",
      "hidden": true
    },
    {
      "name": "release",
      "configuration": "Release",
      "hidden": true
    },
    {
      "name": "cpp",
      "targets": [
        "MSCL-Cpp"
      ],
      "hidden": true
    },
    {
      "name": "tests",
      "targets": [
        "MSCL-Tests"
      ],
      "hidden": true
    },
    {
      "name": "cpp-examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    },
    {
      "name": "python2",
      "targets": [
        "MSCL-Python2"
      ],
      "hidden": true
    },
    {
      "name": "python2-examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    },
    {
      "name": "python3",
      "targets": [
        "MSCL-Python3"
      ],
      "hidden": true
    },
    {
      "name": "python3-examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    }
  ]
}
