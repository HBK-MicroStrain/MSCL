{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "configure.json"
  ],
  "buildPresets": [
    {
      "name": "cpp",
      "displayName": "Builds C++ libraries",
      "description": "This builds C++ libraries",
      "targets": [
        "MSCL-Cpp"
      ],
      "hidden": true
    },
    {
      "name": "static",
      "displayName": "Builds static C++ libraries",
      "description": "This builds static C++ libraries",
      "inherits": [
        "cpp"
      ],
      "hidden": true
    },
    {
      "name": "shared",
      "displayName": "Builds shared C++ libraries",
      "description": "This builds shared C++ libraries",
      "inherits": [
        "cpp"
      ],
      "hidden": true
    },
    {
      "name": "tests",
      "displayName": "Builds unit tests",
      "description": "This builds unit tests",
      "targets": [
        "MSCL-Tests"
      ],
      "hidden": true
    },
    {
      "name": "cpp-examples",
      "displayName": "Builds C++ examples",
      "description": "This builds C++ examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    },
    {
      "name": "python2",
      "displayName": "Builds Python2 bindings",
      "description": "This builds Python2 bindings",
      "targets": [
        "MSCL-Python2"
      ],
      "hidden": true
    },
    {
      "name": "python2-examples",
      "displayName": "Builds Python2 examples",
      "description": "This builds Python2 examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    },
    {
      "name": "python3",
      "displayName": "Builds Python3 bindings",
      "description": "This builds Python3 bindings",
      "targets": [
        "MSCL-Python3"
      ],
      "hidden": true
    },
    {
      "name": "python3-examples",
      "displayName": "Builds Python3 examples",
      "description": "This builds Python3 examples",
      "targets": [
        "MSCL-Examples"
      ],
      "hidden": true
    },
    {
      "name": "static-all",
      "displayName": "Builds all configurations with static C++ libraries",
      "description": "This builds all configurations with static C++ libraries",
      "inherits": [
        "static",
        "tests",
        "cpp-examples",
        "python3"
      ],
      "hidden": true
    }
  ]
}
