{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "include": [
    "configure.json"
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Default test configuration",
      "description": "This is the default test configuration",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "stopOnFailure": false,
        "noTestsAction": "error",
        "jobs": 4
      },
      "hidden": true
    }
  ]
}
