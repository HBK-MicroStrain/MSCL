{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Config",
      "description": "Default configuration",
      "binaryDir": "${sourceDir}/build/$env{MICROSTRAIN_BUILD_SUBDIR}",
      "generator": "Ninja",
      "environment": {
        "VCPKG_BINARY_SOURCES": "$penv{VCPKG_BINARY_SOURCES}"
      },
      "hidden": true
    },
    {
      "name": "package",
      "displayName": "Package configuration",
      "description": "This configuration enables packaging",
      "cacheVariables": {
        "MSCL_BUILD_PACKAGE": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "shared",
      "displayName": "Shared library configuration",
      "description": "This configuration enables shared library building",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "shared-package",
      "displayName": "Shared library package configuration",
      "description": "This configuration enables shared library packaging",
      "inherits": [
        "shared",
        "package"
      ],
      "hidden": true
    },
    {
      "name": "tests",
      "displayName": "Enables unit testing",
      "description": "This configuration enables unit testing",
      "cacheVariables": {
        "MSCL_BUILD_TESTS": "ON"
      },
      "hidden": true
    },
    {
      "name": "cpp-examples",
      "displayName": "Enable C++ examples",
      "description": "This configuration enables C++ examples",
      "cacheVariables": {
        "MSCL_BUILD_CPP_EXAMPLES": "ON"
      },
      "hidden": true
    },
    {
      "name": "cpp-examples-package",
      "displayName": "Enable packaging C++ examples",
      "description": "This configuration enables packaging C++ examples",
      "inherits": [
        "cpp-examples",
        "package"
      ],
      "hidden": true
    },
    {
      "name": "python2",
      "displayName": "Enable Python2 bindings",
      "description": "This configuration enables Python2 bindings",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON2": "ON"
      },
      "hidden": true
    },
    {
      "name": "python2-package",
      "displayName": "Enable packaging Python2 bindings",
      "description": "This configuration enables packaging Python2 bindings",
      "inherits": [
        "python2",
        "package"
      ],
      "hidden": true
    },
    {
      "name": "python2-examples",
      "displayName": "Enable Python2 examples",
      "description": "This configuration enables Python2 examples",
      "inherits": "python2",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON_EXAMPLES": "ON"
      },
      "hidden": true
    },
    {
      "name": "python2-examples-package",
      "displayName": "Enable packaging Python2 examples",
      "description": "This configuration enables packaging Python2 examples",
      "inherits": [
        "python2-examples",
        "package"
      ],
      "hidden": true
    },
    {
      "name": "python3",
      "displayName": "Enable Python3 bindings",
      "description": "This configuration enables Python3 bindings",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON3": "ON"
      },
      "hidden": true
    },
    {
      "name": "python3-package",
      "displayName": "Enable packaging Python3 bindings",
      "description": "This configuration enables packaging Python3 bindings",
      "inherits": [
        "python3",
        "package"
      ],
      "hidden": true
    },
    {
      "name": "python3-examples",
      "displayName": "Enable Python3 examples",
      "description": "This configuration enables Python3 examples",
      "inherits": "python3",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON_EXAMPLES": "ON"
      },
      "hidden": true
    },
    {
      "name": "python3-examples-package",
      "displayName": "Enable packaging Python3 examples",
      "description": "This configuration enables packaging Python3 examples",
      "inherits": [
        "python3-examples",
        "package"
      ],
      "hidden": true
    }
  ]
}
