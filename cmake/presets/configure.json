{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default Config",
      "description": "Default configuration",
      "binaryDir": "${sourceDir}/build/$env{MICROSTRAIN_BUILD_SUBDIR}",
      "generator": "Ninja",
      "environment": {
        "VCPKG_BINARY_SOURCES": "$penv{VCPKG_BINARY_SOURCES}"
      },
      "hidden": true
    },
    {
      "name": "shared",
      "displayName": "Shared library configuration",
      "description": "This configuration enables shared library building",
      "inherits": "default",
      "cacheVariables": {
        "BUILD_SHARED_LIBS": {
          "type": "BOOL",
          "value": "ON"
        }
      },
      "hidden": true
    },
    {
      "name": "tests",
      "displayName": "Enables unit testing",
      "description": "This configuration enables unit testing",
      "inherits": "default",
      "cacheVariables": {
        "MSCL_BUILD_TESTS": "ON"
      },
      "hidden": true
    },
    {
      "name": "cpp-examples",
      "displayName": "Enable C++ examples",
      "description": "This configuration enables C++ examples",
      "inherits": "default",
      "cacheVariables": {
        "MSCL_BUILD_CPP_EXAMPLES": "ON"
      },
      "hidden": true
    },
    {
      "name": "python2",
      "displayName": "Enable Python2 bindings",
      "description": "This configuration enables Python2 bindings",
      "inherits": "default",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON2": "ON"
      },
      "hidden": true
    },
    {
      "name": "python2-examples",
      "displayName": "Enable Python2 examples",
      "description": "This configuration enables Python2 examples",
      "inherits": "python2",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON_EXAMPLES": "ON"
      },
      "hidden": true
    },
    {
      "name": "python3",
      "displayName": "Enable Python3 bindings",
      "description": "This configuration enables Python3 bindings",
      "inherits": "default",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON3": "ON"
      },
      "hidden": true
    },
    {
      "name": "python3-examples",
      "displayName": "Enable Python3 examples",
      "description": "This configuration enables Python3 examples",
      "inherits": "python3",
      "cacheVariables": {
        "MSCL_BUILD_PYTHON_EXAMPLES": "ON"
      },
      "hidden": true
    }
  ]
}
